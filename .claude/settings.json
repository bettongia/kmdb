{
  "permissions": {
    "allow": []
  },
  "sandbox": {
    "enabled": true,
    "filesystem": {
      "denyRead": ["~/"],
      "allowRead": ["./", "~/.pub-cache", "~/.gitconfig"],
      "allowWrite": ["./"]
    }
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.command' | grep -q 'git commit' && make pre_commit || true"
          }
        ]
      }
    ]
  }
}
