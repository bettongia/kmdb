{
  "permissions": {
    "allow": [
      "Bash(make pre_commit)",
      "Write",
      "Edit",
      "Bash(dart *)",
      "Bash(git *)",
      "Bash(find *)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(cp *)",
      "Bash(mkdir *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.command' | grep -q 'git commit' && make pre_commit || true"
          }
        ]
      }
    ]
  },
  "sandbox": {
    "enabled": true,
    "filesystem": {
      "allowWrite": [
        "./"
      ],
      "denyRead": [
        "~/"
      ],
      "allowRead": [
        "./",
        "~/.pub-cache",
        "~/.gitconfig"
      ]
    }
  }
}
