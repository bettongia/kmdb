{
  "permissions": {
    "allow": []
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.command' | grep -q 'git commit' && make pre_commit || true"
          }
        ]
      }
    ]
  },
  "sandbox": {
    "enabled": true,
    "filesystem": {
      "allowWrite": ["./"],
      "denyRead": ["~/"],
      "allowRead": ["./", "~/.gitconfig", "~/flutter", "~/.pub-cache"]
    }
  }
}
