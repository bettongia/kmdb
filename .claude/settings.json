{
  "permissions": {
    "allow": [
      "Read(//Users/gonk/development/kmesh/packages/registry_freedesktop_mimeinfo/**)",
      "Read(//Users/gonk/development/kmesh/**)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.command' | grep -q 'git commit' && make pre_commit || true"
          }
        ]
      }
    ]
  },
  "sandbox": {
    "enabled": true,
    "filesystem": {
      "allowWrite": [
        "./"
      ],
      "denyRead": [
        "~/"
      ],
      "allowRead": [
        "./",
        "~/.pub-cache",
        "~/.gitconfig"
      ]
    }
  }
}
