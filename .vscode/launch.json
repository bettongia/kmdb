  "version": "0.2.0",
  "configurations": [
    {
      "name": "CLI - Add a value",
      "type": "dart",
      "request": "launch",
      "program": "packages/kmdb_cli/bin/kmdb.dart",
      "args": [
        "/tmp/mydb",
        "put",

        "--value '{\"id\":\"019242f4aac07b8fb7e8f1bfb2c3d4e5\",\"title\":\"Hello\"}'"
      ]
    },
    {
      "name": "CLI - Get info",
      "type": "dart",
      "request": "launch",
      "program": "packages/kmdb_cli/bin/kmdb.dart",
      "args": ["/tmp/mydb", "info"]
    }
  ]
}
